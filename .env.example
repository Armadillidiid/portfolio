# Public site URL. Used for absolute URLs in RSS, sitemap, og:image meta.
VITE_SITE_URL=https://emmanuelisenah.com

# Google Tag Manager container ID, e.g. GTM-ABC1234DE.
# Leave empty to disable GTM entirely.
VITE_GTM_ID=

# Giscus comment system — set these after installing giscus app on the repo.
VITE_GISCUS_REPO_ID=
VITE_GISCUS_CATEGORY_ID=
