{
  "name": "portfolio",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node server.js",
    "typecheck": "tsc --noEmit",
    "build:content": "node scripts/keystatic-content.mjs",
    "build:client": "vp build",
    "build:ssr": "vp build --ssr src/entry-server.tsx",
    "build:prerender": "node scripts/prerender.mjs",
    "build": "vp run build:content && vp run typecheck && vp run build:client && vp run build:ssr && vp run build:prerender",
    "preview": "vp preview",
    "deploy:pages": "wrangler pages deploy dist/client --project-name=portfolio --branch=main --commit-dirty=true",
    "deploy": "vp run build && vp run deploy:pages",
    "prepare": "vp config",
    "migrate:posts": "node scripts/migrate-posts.mjs"
  },
  "dependencies": {
    "@base-ui/react": "^1.5.0",
    "@expressive-code/plugin-collapsible-sections": "^0.43.1",
    "@expressive-code/plugin-line-numbers": "^0.43.1",
    "@fontsource-variable/geist": "^5.2.9",
    "@fontsource-variable/jetbrains-mono": "catalog:",
    "@giscus/react": "^3.1.0",
    "@keystatic/core": "^0.5.51",
    "@tailwindcss/vite": "^4.3.1",
    "@tanstack/react-devtools": "^0.10.7",
    "@tanstack/react-router": "catalog:",
    "@tanstack/router-plugin": "catalog:",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.4.0",
    "deepmerge": "^4.3.1",
    "embla-carousel-react": "^8.6.0",
    "expressive-code": "^0.43.1",
    "gray-matter": "catalog:",
    "hast-util-to-html": "^9.0.5",
    "input-otp": "^1.4.2",
    "lucide-react": "^1.18.0",
    "next-themes": "^0.4.6",
    "radix-ui": "^1.5.0",
    "react": "^19.2.7",
    "react-day-picker": "^10.0.1",
    "react-dom": "^19.2.7",
    "react-markdown": "^10.1.0",
    "react-resizable-panels": "^4.11.2",
    "recharts": "3.8.0",
    "remark-gfm": "^4.0.1",
    "shiki": "^4.2.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.1",
    "tw-animate-css": "^1.4.0",
    "vaul": "^1.1.2",
    "void": "catalog:"
  },
  "devDependencies": {
    "@types/node": "^25.9.3",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "sharp": "^0.35.2",
    "typescript": "~6.0.3",
    "vite": "catalog:",
    "vite-plus": "catalog:",
    "wrangler": "^4.42.0"
  },
  "devEngines": {
    "packageManager": {
      "name": "pnpm",
      "version": "11.1.2",
      "onFail": "download"
    }
  },
  "engines": {
    "node": ">=26"
  },
  "packageManager": "pnpm@11.1.2"
}
