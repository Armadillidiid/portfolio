# Copy to .env.local and fill in. Never commit .env.local.

# Public site URL. Used for absolute URLs in RSS, sitemap, og:image meta.
# Production: set this in your hosting provider's env (e.g. Cloudflare / Void).
VITE_SITE_URL=https://example.com

# Google Tag Manager container ID, e.g. GTM-ABC1234DE.
# Leave empty to disable GTM entirely.
VITE_GTM_ID=
